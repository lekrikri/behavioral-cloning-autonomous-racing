   "source": ["# EDA — Robocar Racing Simulator\n", "Analyse exploratoire du dataset de conduite collecté."]
  },
  {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [],
   "source": ["import sys\nsys.path.insert(0, '..')\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport matplotlib.gridspec as gridspec\nimport seaborn as sns\nfrom pathlib import Path\n\nplt.style.use('seaborn-v0_8-whitegrid')\nsns.set_palette('husl')\nprint('Libs OK')"]
  },
  {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [],
   "source": ["# Charger le dataset\nDATA_DIR = Path('../data')\ncsv_files = list(DATA_DIR.glob('*.csv'))\nprint(f'CSV trouvés: {[f.name for f in csv_files]}')\n\nif csv_files:\n    dfs = [pd.read_csv(f) for f in csv_files]\n    df = pd.concat(dfs, ignore_index=True)\nelse:\n    # Générer des données synthétiques pour tester\n    from src.dataset import generate_synthetic_data\n    generate_synthetic_data(n_samples=3000, n_rays=10, output_path='../data/synthetic.csv')\n    df = pd.read_csv('../data/synthetic.csv')\n\nprint(f'Dataset: {len(df)} frames, {df.shape[1]} colonnes')\ndf.head()"]
  },
  {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [],
   "source": ["# Stats descriptives\nprint(df.describe().round(3))"]
  },
  {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [],
   "source": ["# Distribution des actions\nfig, axes = plt.subplots(1, 3, figsize=(15, 4))\nfig.suptitle('Distribution des actions et vitesse', fontsize=13)\n\naxes[0].hist(df['steering'], bins=60, color='#2196F3', edgecolor='white', alpha=0.8)\naxes[0].axvline(0, color='red', linestyle='--', alpha=0.7)\naxes[0].set_title('Steering')\naxes[0].set_xlabel('Valeur [-1, 1]')\n\naxes[1].hist(df['acceleration'], bins=60, color='#FF5722', edgecolor='white', alpha=0.8)\naxes[1].axvline(0, color='red', linestyle='--', alpha=0.7)\naxes[1].set_title('Acceleration')\naxes[1].set_xlabel('Valeur [-1, 1]')\n\naxes[2].hist(df['speed'], bins=60, color='#4CAF50', edgecolor='white', alpha=0.8)\naxes[2].set_title('Speed')\naxes[2].set_xlabel('Valeur [0, 1]')\n\nplt.tight_layout()\nplt.show()\n\n# Vérifier le déséquilibre gauche/droite\npos_steer = (df['steering'] > 0.1).sum()\nneg_steer = (df['steering'] < -0.1).sum()\nneutral = len(df) - pos_steer - neg_steer\nprint(f'Steering — Droite: {pos_steer} ({100*pos_steer/len(df):.1f}%) | Gauche: {neg_steer} ({100*neg_steer/len(df):.1f}%) | Neutre: {neutral} ({100*neutral/len(df):.1f}%)')"]
  },
  {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [],
   "source": ["# Heatmap des rayons\nray_cols = [c for c in df.columns if c.startswith('ray_')]\nfig, axes = plt.subplots(1, 2, figsize=(14, 5))\n\n# Distribution des rayons\ndf[ray_cols].boxplot(ax=axes[0])\naxes[0].set_title('Distribution des rayons (capteurs)')\naxes[0].set_xlabel('Rayon')\naxes[0].set_ylabel('Distance normalisée')\naxes[0].tick_params(axis='x', rotation=45)\n\n# Corrélation rayons / steering\ncorr = df[ray_cols + ['steering']].corr()\nsns.heatmap(corr, ax=axes[1], cmap='RdBu_r', center=0, annot=True, fmt='.2f', square=True)\naxes[1].set_title('Corrélation rayons / steering')\nplt.tight_layout()\nplt.show()"]
  },
  {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [],
   "source": ["# Analyse temporelle\nfig, axes = plt.subplots(2, 1, figsize=(15, 8), sharex=True)\nn = min(1000, len(df))\nt = range(n)\n\naxes[0].plot(t, df['steering'][:n], label='Steering', alpha=0.8)\naxes[0].axhline(0, color='black', linestyle='--', alpha=0.3)\naxes[0].set_ylabel('Steering')\naxes[0].legend()\n\naxes[1].plot(t, df['acceleration'][:n], label='Acceleration', color='#FF5722', alpha=0.8)\naxes[1].plot(t, df['speed'][:n], label='Speed', color='#4CAF50', alpha=0.8)\naxes[1].axhline(0, color='black', linestyle='--', alpha=0.3)\naxes[1].set_ylabel('Valeur')\naxes[1].set_xlabel('Frame')\naxes[1].legend()\n\nfig.suptitle('Série temporelle (1000 premiers frames)')\nplt.tight_layout()\nplt.show()"]
  },
  {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [],
   "source": ["# Scatter plot steering vs speed\nfig, axes = plt.subplots(1, 2, figsize=(12, 5))\n\naxes[0].scatter(df['speed'], df['steering'], alpha=0.1, s=5)\naxes[0].set_xlabel('Speed')\naxes[0].set_ylabel('Steering')\naxes[0].set_title('Steering vs Speed')\n\naxes[1].scatter(df['steering'], df['acceleration'], alpha=0.1, s=5, c=df['speed'], cmap='YlOrRd')\naxes[1].set_xlabel('Steering')\naxes[1].set_ylabel('Acceleration')\naxes[1].set_title('Steering vs Acceleration (couleur=speed)')\nplt.colorbar(axes[1].collections[0], ax=axes[1], label='Speed')\nplt.tight_layout()\nplt.show()"]
  },
  {"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [],
   "source": ["# Rapport de qualite\nprint('=== RAPPORT QUALITÉ DU DATASET ===')\nprint(f'Total frames:      {len(df):,}')\nprint(f'Colonnes:          {list(df.columns)}')\nprint(f'Valeurs manquantes: {df.isnull().sum().sum()}')\nprint()\nprint('Actions:')\nprint(f'  Steering  - mean={df.steering.mean():.3f}, std={df.steering.std():.3f}')\nprint(f'  Accel     - mean={df.acceleration.mean():.3f}, std={df.acceleration.std():.3f}')\nprint(f'  Speed     - mean={df.speed.mean():.3f}, std={df.speed.std():.3f}')\nprint()\n# Détecter les doublons\ndupes = df.duplicated().sum()\nprint(f'Doublons: {dupes}')\n# Frames à l\'arrêt\nstopped = (df.speed < 0.05).sum()\nprint(f'Frames à l\'arrêt (<0.05): {stopped} ({100*stopped/len(df):.1f}%)')"]
  }
