# Robocar — central car parameters. Edit this to set up the car.
# Loaded by src/mapping/car_config.py (plain KEY=VALUE, no dependency).
# Missing keys fall back to the defaults in car_config.py.

# --- Camera mounting (OAK-D Lite) — used by PolarRays / IPM ---
CAM_HEIGHT_M=0.31          # lens height above ground (provisional; mounts being printed)
CAM_PITCH_DEG=13.5         # downward tilt from horizontal (provisional)
CAM_HFOV_DEG=68.8          # color horizontal FOV (measured)
CAM_WIDTH=512              # hub color frame width
CAM_HEIGHT_PX=256          # hub color frame height

# --- VESC control ---
VESC_PORT=/dev/ttyACM0
VESC_MAX_CURRENT=15.0      # A, |current| cap
VESC_MAX_DUTY=0.20
VESC_SERVO_CENTER=0.53     # straight (calibrated 2026-06-24; linkage has backlash)
VESC_SERVO_RANGE=0.40
VESC_INVERT_MOTOR=false    # this car drives forward with invert OFF
VESC_THROTTLE_MODE=current
VESC_K_ERPM_TO_MS=0.000219 # v(m/s) = k * eRPM (calibrated)
VESC_ERPM_SIGN=-1.0        # forward reads as negative eRPM on this car

# --- IMU / pose ---
GYRO_YAW_AXIS=2            # 0=x 1=y 2=z (confirm after final mount)
GYRO_YAW_SIGN=1.0
GYRO_BIAS_SECONDS=2.0

# --- Perception (polar rays via IPM) ---
N_RAYS=20
RAY_MAX_M=4.0
ROW_BAND_LO=0.0            # IPM: ground fills most of a low forward-down camera's frame
ROW_BAND_HI=1.0

# --- Hub / telemetry ---
HUB_HOST=127.0.0.1
HUB_PORT=8077
HUB_IMU_PORT=8078
HUB_DEPTH_PORT=8079
TELEMETRY_PORT=5602
DEPTH_FILTER_TOL=0.35      # reject mask pixels closer than (1-tol)*ground depth

# --- Occupancy grid (mapping) ---
GRID_RES_M=0.05
GRID_SIZE_M=20.0
